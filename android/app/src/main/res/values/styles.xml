<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Theme applied to the Android Window while the process is
         starting. We make this a SOLID PARCHMENT screen (no icon, no
         logo) so the user sees the same parchment colour as the HTML
         splash (indexIntro.html) without a white flash or app-icon
         flash beforehand. -->
    <style name="LaunchTheme" parent="@android:style/Theme.Light.NoTitleBar">
        <item name="android:windowBackground">@drawable/launch_background</item>
    </style>
    <!-- Theme applied to the Android Window once the process has
         started but before Flutter has drawn its first frame. Also
         parchment so there is no flash between LaunchTheme and the
         Flutter UI. -->
    <style name="NormalTheme" parent="@android:style/Theme.Light.NoTitleBar">
        <item name="android:windowBackground">@color/parchment</item>
    </style>
</resources>
