<?xml version="1.0" encoding="utf-8"?>
<!-- Pre-Flutter splash background. Solid parchment (#F4ECD8), the
     same colour the HTML splash (indexIntro.html) paints, so the
     Android launch window, the Flutter NormalTheme window, and our
     HTML splash all read as one continuous parchment screen. No
     white flash, no app-icon overlay before our title text. -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:drawable="@color/parchment" />
</layer-list>
