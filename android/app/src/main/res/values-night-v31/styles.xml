<?xml version="1.0" encoding="utf-8"?>
<!-- Night-mode counterpart of values-v31/styles.xml. Same parchment
     splash, no icon overlay, regardless of system dark mode. -->
<resources>
    <style name="LaunchTheme" parent="@android:style/Theme.Black.NoTitleBar">
        <item name="android:windowBackground">@drawable/launch_background</item>
        <item name="android:windowSplashScreenBackground">@color/parchment</item>
        <item name="android:windowSplashScreenAnimatedIcon">@drawable/splash_icon_transparent</item>
    </style>
    <style name="NormalTheme" parent="@android:style/Theme.Black.NoTitleBar">
        <item name="android:windowBackground">@color/parchment</item>
    </style>
</resources>
