# Miscellaneous
*.class
*.log
*.pyc
*.swp
.DS_Store
.atom/
.build/
.buildlog/
.history
.svn/
.swiftpm/
migrate_working_dir/

# IntelliJ related
*.iml
*.ipr
*.iws
.idea/

# The .vscode folder contains launch configuration and tasks you configure in
# VS Code which you may wish to be included in version control, so this line
# is commented out by default.
#.vscode/

# Flutter/Dart/Pub related
**/doc/api/
**/ios/Flutter/.last_build_id
.dart_tool/
.flutter-plugins
.flutter-plugins-dependencies
.pub-cache/
.pub/
/build/
/coverage/

# iOS — generated by `flutter pub get`
ios/Flutter/Generated.xcconfig
ios/Flutter/flutter_export_environment.sh
ios/Flutter/ephemeral/
ios/.symlinks/
ios/Pods/

# Android — gradle cache
android/.gradle/
android/local.properties
android/captures/

# Symbolication related
app.*.symbols

# Obfuscation related
app.*.map.json

# Android Studio will place build artifacts here
/android/app/debug
/android/app/profile
/android/app/release

# Signing material — never publish
android/key.properties
*.keystore
*.jks

# Internal developer notes (kept locally only)
/.notes/

# Scrape cache (regenerated by build script; not redistributable)
scripts/_cache_tikunkorim/
scripts/__pycache__/

# Internal data-pipeline scripts (kept out of the public repo so
# this repository hosts the *app* rather than the build pipeline).
# The generated JSON in assets/html/data/ is committed; the scripts
# that produce it are not.
scripts/scrape_tikunkorim.py
scripts/build_from_tikunkorim.py
scripts/inspect_column.py
scripts/list_col_totals.py

# Release artifacts (built locally, not redistributed via repo)
release_v1/

# Local environment
.env
.env.local

# node_modules anywhere in the tree (dev tooling for the build
# script — re-installed via `npm install` in scripts/calendar-build/)
**/node_modules/
